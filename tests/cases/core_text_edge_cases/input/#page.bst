import @core/text {length, is_empty, contains, starts_with, ends_with}

len_empty = length("")
len_emoji = length("😊")
empty_yes = is_empty("")
empty_no = is_empty("a")
contains_empty_text = contains("abc", "")
contains_empty_both = contains("", "")
starts_empty_text = starts_with("abc", "")
starts_empty_both = starts_with("", "")
ends_empty_text = ends_with("abc", "")
ends_empty_both = ends_with("", "")

io([:len_empty=[len_empty] len_emoji=[len_emoji] empty_yes=[empty_yes] empty_no=[empty_no] contains_empty_text=[contains_empty_text] contains_empty_both=[contains_empty_both] starts_empty_text=[starts_empty_text] starts_empty_both=[starts_empty_both] ends_empty_text=[ends_empty_text] ends_empty_both=[ends_empty_both]])
