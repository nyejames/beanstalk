one #Float = cast "1" catch: then 0.0;
ptfive #Float = cast "1.5" catch: then 0.0;
neg #Float = cast "-1.5" catch: then 0.0;
exp #Float = cast "1e6" catch: then 0.0;
big #Float = cast "1e+21" catch: then 0.0;
small #Float = cast "1e-6" catch: then 0.0;
under #Float = cast "1_000.5e-2" catch: then 0.0;

[: [one]|[ptfive]|[neg]|[exp]|[big]|[small]|[under]]
