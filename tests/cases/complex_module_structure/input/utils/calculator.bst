-- Calculator utility module
compute |a Int, b Int| -> Int:
    result = a + b
    io.line([: Computing: [a] + [b] = [result]])
    return result
;

multiply |a Int, b Int| -> Int:
    result = a * b
    io.line([: Multiplying: [a] * [b] = [result]])
    return result
;

init_calculator ||:
    io.line("Calculator module initialized")
;
