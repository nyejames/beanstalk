-- Ordinary implementation file private to the helper module.
-- The facade (#mod.bst) re-exports these declarations across the module boundary.

Counter = |
    step Int,
|

-- Returns an alias of the shared parameter, declared with the `-> value` alias-return form.
alias_of |value Counter| -> value:
    return value
;

-- Returns a fresh, independently owned value.
fresh_counter || -> Counter:
    return Counter(0)
;

-- Mutates an existing mutable place passed by the caller.
bump |value ~Counter|:
    value.step = value.step + 1
;
