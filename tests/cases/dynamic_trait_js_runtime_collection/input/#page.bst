DISPLAY_TEXT must:
    display |This| -> String
;

Label = |
    text String,
|

display |this Label| -> String:
    return this.text
;

Label must DISPLAY_TEXT

items {DISPLAY_TEXT} = {Label("first"), Label("second")}
text ~= ""

loop items |item|:
    text = text + item.display()
;

[:collection=[text]]
