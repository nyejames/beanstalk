import @./helper_a { label_a }
import @./helper_b { label_b }
import @./helper_c { label_c }
import @./helper_d { label_d }
import @./helper_e { label_e }
import @./helper_f { label_f }
import @./helper_g { label_g }
import @./helper_h { label_h }

-- Combine labels from every helper so the rendered output proves all imports compiled.
combined #= [:[label_a][label_b][label_c][label_d][label_e][label_f][label_g][label_h]]

#[:<p id="chunked">[combined]</p>]
