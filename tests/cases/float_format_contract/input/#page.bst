-- float_format_contract: backend-stable Float -> String formatting coverage.
--
-- This test exercises both the compile-time/folded path and the runtime path for
-- Float -> String formatting, locking the exact output contract for all required
-- edge cases:
--   0.0       -> "0"
--   -0.0      -> "0"     (negative zero normalised)
--   1.0       -> "1"
--   1.5       -> "1.5"
--   0.000001  -> "0.000001"
--   0.0000001 -> "1e-7"  (below 1e-6 threshold uses exponential)
--   1e21      -> "1e+21"
--   -1e21     -> "-1e+21"

-- ---------------------------
--  Compile-time/folded path
-- ---------------------------
-- Float constants interpolated in a top-level template fold at compile time,
-- proving the AST constant-folding path agrees with the runtime formatter.

zero #Float = 0.0
neg_zero #Float = -0.0
one #Float = 1.0
one_half #Float = 1.5
small #Float = 0.000001
tiny #Float = 0.0000001
big #Float = 1e21
neg_big #Float = -1e21

[: [zero]|[neg_zero]|[one]|[one_half]|[small]|[tiny]|[big]|[neg_big]]

-- ---------------------
--  Runtime path
-- ---------------------
-- An explicit Float -> String cast inside a function body exercises
-- HirStatementKind::FormatFloat and the JS __bs_format_float helper.

format_value |value Float| -> String:
    text String = cast value
    return text
;

[: [format_value(0.0)]|[format_value(-0.0)]|[format_value(1.0)]|[format_value(1.5)]|[format_value(0.000001)]|[format_value(0.0000001)]|[format_value(1e21)]|[format_value(-1e21)]]
