-- Prove multiple runtime fragments mount in source order.
-- Two top-level template expressions create bst-slot-0 and bst-slot-1 entries in page.js.

render_first || -> String:
    return "content from slot zero"
;

render_second || -> String:
    return "content from slot one"
;

first_msg = render_first()
second_msg = render_second()
[:Slot0: [first_msg]]
[:Slot1: [second_msg]]
