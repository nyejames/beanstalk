-- Test that Beanstalk operators map to the correct JS operators.
-- Validates the operator lowering table for arithmetic, comparison, and logical ops.

a = 10
b = 3

-- Arithmetic
sum = a + b
diff = a - b
prod = a * b
quot = a / b
rem = a % b

-- Comparison
eq = a is b
neq = a is not b
lt = a < b
gt = a > b
le = a <= b
ge = a >= b

-- Logical (use variables to prevent constant folding)
flag1 = true
flag2 = false
both = flag1 and flag2
either = flag1 or flag2
negated = not flag1

io(sum)
io(eq)
io(both)
