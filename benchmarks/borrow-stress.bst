-- borrow-stress.bst
-- Valid borrow/exclusivity stress benchmark.

Counter = |
    value Int,
|

Bucket = |
    label String,
    count Int,
|

increment |this ~Counter|:
    this.value = this.value + 1
;

add |this ~Counter, amount Int|:
    this.value = this.value + amount
;

reset |this ~Counter|:
    this.value = 0
;

consume_bucket |bucket ~Bucket| -> String:
    bucket.count = bucket.count + 1
    return [: [bucket.label]:[bucket.count] ]
;

bump_many |counter ~Counter, amount Int|:
    loop 0 to 20 |i|:
        counter.value = counter.value + amount + i
    ;
;

render_counter |counter Counter| -> String:
    return [: counter=[counter.value] ]
;

counter ~= Counter(0)
~counter.increment()
~counter.add(1)
~counter.add(2)
~counter.add(3)
bump_many(~counter, 2)
counter_summary = render_counter(counter)

buckets ~{Bucket} = {}
loop 0 to 12 |i|:
    ~buckets.push(Bucket([: bucket-[i] ], i))
;

messages ~{String} = {}
sample_bucket ~= Bucket("sample", 1)
sample_message = consume_bucket(~sample_bucket)
~messages.push(sample_message)

loop buckets |bucket|:
    message = [: [bucket.label]:[bucket.count] ]
    ~messages.push(message)
;

io(counter_summary)
io([: messages=[messages.length()] ])
