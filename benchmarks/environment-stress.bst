-- environment-stress.bst
-- Stresses AST environment building, type alias expansion, nominal structs
-- and choices, receiver catalog construction, generic declarations and
-- instantiations, and body validation / type resolution.
-- Dense declarations with minimal runtime body.

-- Scalar aliases
Px as Int
Rem as Float
HexColor as String
CssClass as String
EpochMs as Int

-- Collection / option aliases
ClassList as {CssClass}
MaybePx as Px?
MaybeColor as HexColor?

-- Small structs (group 1: layout primitives)
Point = | x Px, y Px |
Size = | width Px, height Px |
Offset = | dx Px, dy Px |
Inset = | top Px, bottom Px |
Radius = | tl Px, tr Px |
Border = | width Px, style String |
Shadow = | x Px, y Px, blur Px, color HexColor |

-- Small structs (group 2: style primitives)
Font = | family String, size Px, weight Int |
ColorStop = | position Float, color HexColor |
Gradient = | start HexColor, end HexColor |
Layer = | index Int, name String |
Frame = | origin Point, size Size |

-- Cross-referencing structs
BoxModel = | content Size, padding Inset, margin Inset |
Positioned = | frame Frame, offset Offset, layer Layer |
Styled = | classes ClassList, font Font, shadow Shadow |
Decorated = | border Border, radius Radius, gradient Gradient |

-- Large field-count structs
NodeConfig = |
    id Int,
    tag String,
    classes ClassList,
    width Px,
    height Px,
    padding Inset,
    margin Inset,
    visible Bool,
|

Theme = |
    name String,
    primary HexColor,
    secondary HexColor,
    background HexColor,
    surface HexColor,
    font_family String,
    font_size Px,
    line_height Rem,
|

-- Unit choices
LayoutMode :: FlowBlock, FlowInline, Flex, Grid;
Visibility :: Visible, Hidden, Collapsed;
Overflow :: Clip, Scroll, Auto;
Cursor :: Default, Pointer, Text, Move;

-- Simple payload choices
OptionalPx ::
    Unset,
    Value | v Px |,
;

OptionalColor ::
    Missing,
    Present | c HexColor |,
;

Toggle ::
    Off,
    On | since EpochMs |,
;

-- Multi-field payload choices
Spacing ::
    Uniform | all Px |,
    Axis | horizontal Px, vertical Px |,
    Edges | top Px, right Px, bottom Px, left Px |,
;

Paint ::
    Solid | color HexColor |,
    Gradient | stops {ColorStop} |,
    Image | url String, repeat Bool |,
;

-- Many-variant payload choice
StyleProp ::
    Default,
    Width | v Px |,
    Height | v Px |,
    Color | c HexColor |,
    Margin | v Px |,
    Padding | v Px |,
    FontSize | v Px |,
;

-- Generic structs
Cell type T = |
    value T,
|

Pair type L, R = |
    left L,
    right R,
|

Wrap type Inner = |
    inner Inner,
    count Int,
|

-- Generic choices
Result type T, E ::
    Ok | value T |,
    Err | error E |,
;

Opt type U ::
    Empty,
    Some | item U |,
;

-- Immutable receiver methods on layout primitives
get_x |this Point| -> Px:
    return this.x
;

get_y |this Point| -> Px:
    return this.y
;

get_width |this Size| -> Px:
    return this.width
;

get_height |this Size| -> Px:
    return this.height
;

get_dx |this Offset| -> Px:
    return this.dx
;

get_dy |this Offset| -> Px:
    return this.dy
;

get_blur |this Shadow| -> Px:
    return this.blur
;

get_shadow_color |this Shadow| -> HexColor:
    return this.color
;

-- Immutable receiver methods on style primitives
get_font_size |this Font| -> Px:
    return this.size
;

get_font_family |this Font| -> String:
    return this.family
;

get_stop_color |this ColorStop| -> HexColor:
    return this.color
;

get_gradient_start |this Gradient| -> HexColor:
    return this.start
;

get_layer_name |this Layer| -> String:
    return this.name
;

get_origin |this Frame| -> Point:
    return this.origin
;

get_frame_size |this Frame| -> Size:
    return this.size
;

-- Immutable receiver methods on cross-referencing structs
get_content |this BoxModel| -> Size:
    return this.content
;

get_frame |this Positioned| -> Frame:
    return this.frame
;

get_font |this Styled| -> Font:
    return this.font
;

get_border |this Decorated| -> Border:
    return this.border
;

-- Immutable receiver methods on large structs
get_tag |this NodeConfig| -> String:
    return this.tag
;

get_theme_name |this Theme| -> String:
    return this.name
;

-- Mutable receiver methods
shift_x |this ~Point, delta Px|:
    this.x = this.x + delta
;

set_width |this ~Size, new_width Px|:
    this.width = new_width
;

set_visible |this ~NodeConfig, visible Bool|:
    this.visible = visible
;

set_name |this ~Theme, name String|:
    this.name = name
;

set_font_size |this ~Font, size Px|:
    this.size = size
;

set_layer_index |this ~Layer, index Int|:
    this.index = index
;

-- Generic free functions
cell_value type T |cell Cell of T| -> T:
    return cell.value
;

extract_left type L, R |left L, right R| -> L:
    return left
;

extract_right type L, R |left L, right R| -> R:
    return right
;

wrap type T |value T| -> Cell of T:
    return Cell(value)
;

pair_of type L, R |left L, right R| -> Pair of L, R:
    return Pair(left, right)
;

identity type T |value T| -> T:
    return value
;

bump_int_wrapper |wrapper ~Wrap of Int|:
    wrapper.count = wrapper.count + 1
;

-- Choice helper functions
is_flex |mode LayoutMode| -> Bool:
    if mode is LayoutMode::Flex:
        return true
    ;
    return false
;

is_visible |state Visibility| -> Bool:
    if state is Visibility::Visible:
        return true
    ;
    return false
;

is_scroll |overflow Overflow| -> Bool:
    if overflow is Overflow::Scroll:
        return true
    ;
    return false
;

is_pointer |cursor Cursor| -> Bool:
    if cursor is Cursor::Pointer:
        return true
    ;
    return false
;

-- Minimal runtime entry to keep the file valid
run_environment_stress ||:
    io("environment stress: declarations only")
;

run_environment_stress()
