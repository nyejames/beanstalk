-- template-render-plan-churn.bst
-- Stresses template render-plan construction: nested composition,
-- slots, inserts, $children wrappers, and runtime template rebuilding.

page_title #= "Template Render Plan Churn"

-- Many small templates to expand the render plan graph.
t_1 #= [: a1 ]
t_2 #= [: [t_1] b2 ]
t_3 #= [: [t_2] c3 ]
t_4 #= [: [t_3] d4 ]
t_5 #= [: [t_4] e5 ]
t_6 #= [: [t_5] f6 ]
t_7 #= [: [t_6] g7 ]
t_8 #= [: [t_7] h8 ]
t_9 #= [: [t_8] i9 ]
t_10 #= [: [t_9] j10 ]

-- Named-slot churn.
shell #= [:
    <!doctype html>
    <html>
    <head><title>[$slot("title")]</title><style>[$slot("style")]</style></head>
    <body>[$slot]</body>
    </html>
]

style_insert #= [$insert("style"):
    body { font-family: system-ui; }
    .line { padding: 0.25rem; }
]

title_insert #= [$insert("title"): [page_title]]

-- Positional-slot churn.
row_template #= [:
    <div class="row">
        <span>[$slot(1)]</span>
        <span>[$slot(2)]</span>
        <span>[$slot(3)]</span>
        <span>[$slot]</span>
    </div>
]

-- Wrapper chains.
wrap_emphasis #= [$children([:<em class="emphasis">[$slot]</em>]):
    [$slot]
]

wrap_strong #= [$children([:<strong class="strong">[$slot]</strong>]):
    [$slot]
]

wrap_code #= [$children([:<code class="code">[$slot]</code>]):
    [$slot]
]

-- Repeated slot replay with default slot.
replay_box #= [:
    <div class="replay">
        <span>[$slot]</span>
        <span>[$slot("body")]</span>
        <span>[$slot("body")]</span>
        <span>[$slot("body")]</span>
    </div>
]

replay_content #= [$insert("body"): repeated]

-- Runtime template construction.
build_lines |count Int| -> String:
    output ~= [: <div class="lines">]
    loop 0 to count |i|:
        output = [: [output]<div class="line">line [i]</div>]
    ;
    output = [: [output]</div>]
    return output
;

build_rows |count Int| -> String:
    output ~= ""
    loop 0 to count |i|:
        row = [row_template, i, i * 2, i * 3: fallback]
        output = [: [output][row]]
    ;
    return output
;

-- Compile-time template DAG.
header #= [: <h1>[page_title]</h1> ]
intro #= [: <p>[t_10] [header]</p> ]
section_a #= [: <section id="a">[intro][replay_box, replay_content: default]</section> ]
section_b #= [: <section id="b">[wrap_emphasis: [wrap_strong: [wrap_code: code block]]]</section> ]

-- Entry
run_template_churn ||:
    io.line("template render plan churn start")

    runtime_lines = build_lines(12)
    runtime_rows = build_rows(8)

    io.line([:
        [shell, style_insert, title_insert:
            [section_a]
            [section_b]
            [runtime_lines]
            [runtime_rows]
        ]
    ])

    io.line("template render plan churn complete")
;

run_template_churn()
