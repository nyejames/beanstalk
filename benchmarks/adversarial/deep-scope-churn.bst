-- deep-scope-churn.bst
-- Stresses scope-frame construction and local declaration churn.
-- Many nested functions and blocks declare locals that cross-reference
-- parent-scope constants and parameters without shadowing.

a0 #= 0
a1 #= 1
a2 #= 2
a3 #= 3
a4 #= 4
a5 #= 5
a6 #= 6
a7 #= 7
a8 #= 8
a9 #= 9

-- Deeply nested function chain; each level adds locals and references outer constants.
level_0 || -> Int:
    v0 = a0 + a1
    return level_1(v0)
;

level_1 |p1 Int| -> Int:
    v1 = p1 + a2
    v2 = a3 * a4
    return level_2(v1, v2)
;

level_2 |p1 Int, p2 Int| -> Int:
    v3 = p1 + p2
    v4 = a5 - a6
    return level_3(v3, v4, a7)
;

level_3 |p1 Int, p2 Int, p3 Int| -> Int:
    v5 = p1 + p2 + p3
    v6 = a8 + a9
    return level_4(v5, v6, a0, a1)
;

level_4 |p1 Int, p2 Int, p3 Int, p4 Int| -> Int:
    v7 = p1 + p2 + p3 + p4
    v8 = a2 * a3
    v9 = a4 + a5
    return level_5(v7, v8, v9, a6, a7)
;

level_5 |p1 Int, p2 Int, p3 Int, p4 Int, p5 Int| -> Int:
    v10 = p1 + p2 + p3 + p4 + p5
    v11 = a8 - a9
    v12 = a0 * a1
    return level_6(v10, v11, v12, a2, a3, a4)
;

level_6 |p1 Int, p2 Int, p3 Int, p4 Int, p5 Int, p6 Int| -> Int:
    v13 = p1 + p2 + p3 + p4 + p5 + p6
    v14 = a5 + a6
    v15 = a7 * a8
    return level_7(v13, v14, v15, a9, a0, a1, a2)
;

level_7 |p1 Int, p2 Int, p3 Int, p4 Int, p5 Int, p6 Int, p7 Int| -> Int:
    v16 = p1 + p2 + p3 + p4 + p5 + p6 + p7
    v17 = a3 - a4
    v18 = a5 + a6
    v19 = a7 * a8
    return level_8(v16, v17, v18, v19, a9, a0, a1, a2)
;

level_8 |p1 Int, p2 Int, p3 Int, p4 Int, p5 Int, p6 Int, p7 Int, p8 Int| -> Int:
    v20 = p1 + p2 + p3 + p4 + p5 + p6 + p7 + p8
    v21 = a3 * a4
    v22 = a5 - a6
    v23 = a7 + a8
    return level_9(v20, v21, v22, v23, a9, a0, a1, a2, a3)
;

level_9 |p1 Int, p2 Int, p3 Int, p4 Int, p5 Int, p6 Int, p7 Int, p8 Int, p9 Int| -> Int:
    v24 = p1 + p2 + p3 + p4 + p5 + p6 + p7 + p8 + p9
    v25 = a4 * a5
    v26 = a6 - a7
    v27 = a8 + a9
    v28 = a0 * a1
    return v24 + v25 + v26 + v27 + v28
;

-- Many nested local scopes inside a single function.
nested_block_churn |seed Int| -> Int:
    l0 = seed + a0
    if l0 > 0:
        l1 = l0 + a1
        if l1 > 0:
            l2 = l1 + a2
            if l2 > 0:
                l3 = l2 + a3
                if l3 > 0:
                    l4 = l3 + a4
                    if l4 > 0:
                        l5 = l4 + a5
                        if l5 > 0:
                            l6 = l5 + a6
                            if l6 > 0:
                                l7 = l6 + a7
                                if l7 > 0:
                                    l8 = l7 + a8
                                    if l8 > 0:
                                        l9 = l8 + a9
                                        return l9
                                    ;
                                    return l8
                                ;
                                return l7
                            ;
                            return l6
                        ;
                        return l5
                    ;
                    return l4
                ;
                return l3
            ;
            return l2
        ;
        return l1
    ;
    return l0
;

-- Dense loop body scope churn.
loop_scope_churn || -> Int:
    accumulator ~= 0
    loop 0 to 20 |i|:
        local_a = i + a0
        local_b = i * a1
        local_c = local_a + local_b
        if local_c > 10:
            local_d = local_c - a2
            accumulator = accumulator + local_d
        ;
        if local_c <= 10:
            local_e = local_c + a3
            accumulator = accumulator + local_e
        ;
    ;
    return accumulator
;

-- Runtime entry
run_deep_scope ||:
    io.line("deep scope churn start")
    result_0 = level_0()
    result_1 = nested_block_churn(5)
    result_2 = loop_scope_churn()
    io.line([: level=[result_0] block=[result_1] loop=[result_2] ])
    io.line("deep scope churn complete")
;

run_deep_scope()
