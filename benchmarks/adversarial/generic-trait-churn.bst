-- generic-trait-churn.bst
-- Stresses generic instantiation, trait conformance, and bound-provided
-- receiver calls through many generic declarations and concrete uses.

-- Traits with distinct method names so multiple types can conform in one file.
DESCRIBED must:
    describe |This| -> String
;

MEASURED must:
    measure |This| -> Float
;

NAMED must:
    item_name |This| -> String
;

RENDERED must:
    render_text |This| -> String
;

-- Concrete types
Point = | x Float, y Float |
Size = | width Float, height Float |
Label = | text String |

-- Receiver methods with unique names
describe |this Point| -> String:
    return [: point-[this.x]-[this.y]]
;

measure |this Point| -> Float:
    return this.x + this.y
;

Point must DESCRIBED
Point must MEASURED

item_name |this Size| -> String:
    return [: [this.width]x[this.height]]
;

Size must NAMED

render_text |this Label| -> String:
    return this.text
;

Label must RENDERED

-- Generic structs
Cell type T = |
    value T,
|

Pair type A, B = |
    first A,
    second B,
|

-- Generic free functions
identity type T |value T| -> T:
    return value
;

cell_value type T |cell Cell of T| -> T:
    return cell.value
;

pair_first type A, B |pair Pair of A, B| -> A:
    return pair.first
;

pair_second type A, B |pair Pair of A, B| -> B:
    return pair.second
;

wrap type T |value T| -> Cell of T:
    return Cell(value)
;

-- Generic functions with trait bounds
render_described type Item is DESCRIBED |item Item| -> String:
    return item.describe()
;

format_named type Item is NAMED |item Item| -> String:
    return [: name=[item.item_name()] ]
;

combine_measures type Item is MEASURED |a Item, b Item| -> Float:
    return a.measure() + b.measure()
;

format_rendered type Item is RENDERED |item Item| -> String:
    return [: text=[item.render_text()] ]
;

-- Generic choice (concrete payload variants, no type parameters)
Status ::
    Pending,
    Active | label String |,
;

status_label |status Status| -> String:
    if status is:
        Pending => return "pending"
        Active(label) => return label
    ;
    return "unknown"
;

-- Concrete instantiations churn
make_int_pair || -> Pair of Int, Int:
    return Pair(10, 20)
;

make_point_cell || -> Cell of Point:
    return Cell(Point(1.0, 2.0))
;

make_float_pair || -> Pair of Float, Float:
    return Pair(1.5, 2.5)
;

make_string_pair || -> Pair of String, String:
    return Pair("hello", "world")
;

-- Runtime entry
run_generic_trait_churn ||:
    io.line("generic trait churn start")

    -- Generic structs
    int_pair = make_int_pair()
    first = pair_first(int_pair)
    second = pair_second(int_pair)
    io.line([: pair=[first],[second] ])

    point_cell = make_point_cell()
    point = cell_value(point_cell)
    io.line([: cell=[point.describe()] ])

    wrapped_label = wrap(Label("wrapped"))
    io.line([: wrapped=[wrapped_label.value.render_text()] ])

    float_pair = make_float_pair()
    io.line([: floats=[float_pair.first + float_pair.second] ])

    string_pair = make_string_pair()
    io.line([: strings=[string_pair.first] [string_pair.second] ])

    -- Trait bounds
    point_a = Point(1.0, 2.0)
    point_b = Point(3.0, 4.0)
    desc = render_described(point_a)
    measure_sum = combine_measures(point_a, point_b)
    io.line([: described=[desc] sum=[measure_sum] ])

    size = Size(10.0, 20.0)
    name = format_named(size)
    io.line([: named=[name] ])

    label = Label("test")
    rendered = format_rendered(label)
    io.line([: rendered=[rendered] ])

    -- Identity churn
    identity_int = identity(42)
    identity_string = identity("hello")
    identity_point = identity(point_a)
    io.line([: ids=[identity_int] [identity_string] [identity_point.describe()] ])

    -- Choice
    status = Status::Active("running")
    io.line([: status=[status_label(status)] ])

    io.line("generic trait churn complete")
;

run_generic_trait_churn()
