-- collection-map-borrow-churn.bst
-- Stresses collection, map, and borrow-checker churn together:
-- repeated mutations, fallible get/remove/clear, and explicit mutable access.

Counter = |
    value Int,
|

increment |this ~Counter|:
    this.value = this.value + 1
;

add |this ~Counter, amount Int|:
    this.value = this.value + amount
;

Item = |
    id Int,
    label String,
|

-- Collection churn: build, mutate, and collapse.
run_collection_churn || -> Int:
    items ~{Int} = {}
    loop 0 to 50 |i|:
        ~items.push(i * 2) catch:
        ;
    ;

    -- Remove stored indices in source order. Later indices may shift, which keeps
    -- the fallible recovery path active without turning the fixture into a
    -- diagnostic case.
    to_remove ~{Int} = {}
    loop items |value, index|:
        if value % 10 is 0:
            ~to_remove.push(index) catch:
            ;
        ;
    ;

    loop to_remove |index|:
        removed = ~items.remove(index) catch:
            then 0
        ;
    ;

    -- Sum remaining items.
    total ~= 0
    loop items |value|:
        total = total + value
    ;
    return total
;

-- Map churn helper: reads and removes on a borrowed mutable map.
map_read_remove |scores ~{String = Int}| -> Int:
    initial_size = scores.length
    removed_beta = ~scores.remove("beta") catch:
        then 0
    ;
    gamma = scores.get("gamma") catch:
        then 0
    ;
    return initial_size + removed_beta + gamma
;

-- Map churn helper: clears and reports final size.
map_clear |scores ~{String = Int}| -> Int:
    ~scores.clear()
    return scores.length
;

-- Map churn: build a mutable map and exercise read/remove/clear.
run_map_churn || -> Int:
    scores ~{String = Int} = {}
    ~scores.set("alpha", 1) catch:
    ;
    ~scores.set("beta", 2) catch:
    ;
    ~scores.set("gamma", 3) catch:
    ;
    ~scores.set("delta", 4) catch:
    ;
    ~scores.set("epsilon", 5) catch:
    ;
    read_sum = map_read_remove(~scores)
    final_size = map_clear(~scores)
    return read_sum + final_size
;

-- Borrow churn: shared and mutable access interleaved safely.
run_borrow_churn || -> String:
    counter ~= Counter(0)
    ~counter.increment()
    ~counter.add(5)
    ~counter.increment()

    label ~= "count:"
    result = [: [label] [counter.value]]
    return result
;

-- Struct collection with mutable receiver churn.
run_struct_collection_churn || -> Int:
    counters ~{Counter} = {}
    loop 0 to 20 |i|:
        ~counters.push(Counter(i)) catch:
        ;
    ;

    total ~= 0
    loop counters |counter|:
        fresh ~= Counter(counter.value)
        ~fresh.increment()
        ~fresh.add(1)
        total = total + fresh.value
    ;
    return total
;

-- Entry
run_collection_map_borrow_churn ||:
    io.line("collection map borrow churn start")

    collection_sum = run_collection_churn()
    map_sum = run_map_churn()
    borrow_result = run_borrow_churn()
    struct_sum = run_struct_collection_churn()

    io.line([: collection=[collection_sum] map=[map_sum] borrow=[borrow_result] struct=[struct_sum] ])

    io.line("collection map borrow churn complete")
;

run_collection_map_borrow_churn()
