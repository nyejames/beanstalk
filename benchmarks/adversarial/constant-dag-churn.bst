-- constant-dag-churn.bst
-- Stresses constant folding and const-template evaluation through a large
-- directed acyclic graph of interdependent constants.

-- Base layer
b00 #= 1
b01 #= 2
b02 #= 3
b03 #= 4
b04 #= 5
b05 #= 6
b06 #= 7
b07 #= 8
b08 #= 9
b09 #= 10

-- Second layer: sums of adjacent base pairs
s00 #= b00 + b01
s01 #= b01 + b02
s02 #= b02 + b03
s03 #= b03 + b04
s04 #= b04 + b05
s05 #= b05 + b06
s06 #= b06 + b07
s07 #= b07 + b08
s08 #= b08 + b09
s09 #= b09 + b00

-- Third layer: products of adjacent sums
p00 #= s00 * s01
p01 #= s01 * s02
p02 #= s02 * s03
p03 #= s03 * s04
p04 #= s04 * s05
p05 #= s05 * s06
p06 #= s06 * s07
p07 #= s07 * s08
p08 #= s08 * s09
p09 #= s09 * s00

-- Fourth layer: mixed arithmetic over products
m00 #= p00 + p01 - p02
m01 #= p01 + p02 - p03
m02 #= p02 + p03 - p04
m03 #= p03 + p04 - p05
m04 #= p04 + p05 - p06
m05 #= p05 + p06 - p07
m06 #= p06 + p07 - p08
m07 #= p07 + p08 - p09
m08 #= p08 + p09 - p00
m09 #= p09 + p00 - p01

-- Fifth layer: integer division and modulo-like patterns
d00 #= (m00 * 7) + 13
d01 #= (m01 * 11) + 17
d02 #= (m02 * 13) + 19
d03 #= (m03 * 17) + 23
d04 #= (m04 * 19) + 29
d05 #= (m05 * 23) + 31
d06 #= (m06 * 29) + 37
d07 #= (m07 * 31) + 41
d08 #= (m08 * 37) + 43
d09 #= (m09 * 41) + 47

-- Sixth layer: deep trees
t00 #= (((b00 + b01) + b02) + b03) + b04
t01 #= (((b05 + b06) + b07) + b08) + b09
t02 #= (((s00 + s01) + s02) + s03) + s04
t03 #= (((s05 + s06) + s07) + s08) + s09
t04 #= (((p00 + p01) + p02) + p03) + p04
t05 #= (((p05 + p06) + p07) + p08) + p09

-- Seventh layer: cross-layer aggregations
a00 #= b00 + s00 + p00 + m00 + d00 + t00
a01 #= b01 + s01 + p01 + m01 + d01 + t01
a02 #= b02 + s02 + p02 + m02 + d02 + t02
a03 #= b03 + s03 + p03 + m03 + d03 + t03
a04 #= b04 + s04 + p04 + m04 + d04 + t04
a05 #= b05 + s05 + p05 + m05 + d05 + t05
a06 #= b06 + s06 + p06 + m06 + d06 + t00
a07 #= b07 + s07 + p07 + m07 + d07 + t01
a08 #= b08 + s08 + p08 + m08 + d08 + t02
a09 #= b09 + s09 + p09 + m09 + d09 + t03

-- Eighth layer: digest digest
layer_8_sum #= a00 + a01 + a02 + a03 + a04 + a05 + a06 + a07 + a08 + a09
layer_8_tree #= ((t00 + t01) * (t02 + t03)) - ((t04 + t05) * 2)
layer_8_final #= layer_8_sum + layer_8_tree

-- String constant DAG
prefix #= "constant"
suffix #= "dag"
word_0 #= [: [prefix]-[suffix] ]
word_1 #= [: [word_0]-[b00] ]
word_2 #= [: [word_1]-[b01] ]
word_3 #= [: [word_2]-[b02] ]
word_4 #= [: [word_3]-[b03] ]
word_5 #= [: [word_4]-[b04] ]
word_6 #= [: [word_5]-[b05] ]
word_7 #= [: [word_6]-[b06] ]
word_8 #= [: [word_7]-[b07] ]
word_9 #= [: [word_8]-[b08] ]

-- Const record DAG
Coord = | x Int, y Int |
c0 #= Coord(b00, b01)
c1 #= Coord(b02, b03)
c2 #= Coord(s00, s01)
c3 #= Coord(p00, p01)

Box = | min Coord, max Coord |
box_0 #= Box(c0, c1)
box_1 #= Box(c2, c3)

-- Compile-time template using the DAG
report #= [:
    <div class="report">
        <p>Final: [layer_8_final]</p>
        <p>Word: [word_9]</p>
        <p>Box: [box_0.min.x] [box_1.max.y]</p>
    </div>
]

-- Runtime entry
run_constant_dag ||:
    io.line("constant dag churn start")
    io.line([: [report] ])
    io.line([: sum=[layer_8_sum] tree=[layer_8_tree] final=[layer_8_final] ])
    io.line([: word=[word_9] ])
    io.line("constant dag churn complete")
;

run_constant_dag()
