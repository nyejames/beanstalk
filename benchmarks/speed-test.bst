# compile_card_a = [card, compile_a_head, compile_a_foot:
    [$markdown:
        ### Fold cluster expansion

        This block is fully compile-time and deliberately dense.

        It exercises:
        - larger arithmetic clusters
        - chained constant references
        - markdown parsing
        - wrapper composition
        - named slot insertion
        - repeated interpolation of large digests

        Snapshot values:
        - fold_01 = [fold_01]
        - fold_02 = [fold_02]
        - fold_03 = [fold_03]
        - fold_04 = [fold_04]
        - fold_05 = [fold_05]
        - digest_a = [digest_a]
    ]

    [bullet_list:
        [: compile-time interpolation ]
        [: markdown rendering ]
        [: const-only captures ]
        [: nested helper composition ]
        [: checksum [digest_a] ]
    ]
]

# compile_card_b = [card, compile_b_head, compile_b_foot:
    [$markdown:
        ### Slots and wrapper edge cases

        This block keeps template composition busy with:
        - repeated positional slot replay
        - named slot helpers
        - direct-child wrappers
        - one child opting out with `$fresh`
    ]

    [chip_row:
        [chip, "↔": positional replay]
        [chip, "↔": grand [grand_digest]]
        [chip, "↔": alt [alt_digest]]
    ]

    [fresh_list:
        [: wrapped item one ]
        [$fresh: [: fresh item bypasses li wrapper ]]
        [: wrapped item two ]
        [: wrapped item three ]
    ]
]

# compile_card_c = [card, compile_c_head, compile_c_foot:
    [$markdown:
        ### Formatter paths

        This block mixes formatter-like directives in one compile-time card.
    ]

    [html_snippet]

    [raw_code_box:
function benchmark(seed) {
    return (seed * 7) + 13;
}
    ]

    [escaped_snippet]
]

# compile_card_d = [card, compile_d_head, compile_d_foot:
    [$markdown:
        ### Nested direct-child wrappers

        The table below uses one `$children(..)` wrapper for rows and another nested one for cells.
    ]

    [compare_table:
        [: [: Surface ] [: Purpose ] [: Example stress ] ]
        [: [: slots ] [: composition paths ] [: named + positional + replay ] ]
        [: [: wrappers ] [: helper elimination ] [: direct-child and `$fresh` mixing ] ]
        [: [: loops ] [: runtime body churn ] [: collection + range + descending + nested ] ]
        [: [: collections ] [: builtin mutation ] [: push + set + remove + get fallback ] ]
    ]
]

# compile_card_e = [card, compile_e_head, compile_e_foot:
    [$markdown:
        ### Digest pressure

        Additional values keep constant resolution and interpolation noisy:
        - fold_11 = [fold_11]
        - fold_12 = [fold_12]
        - fold_13 = [fold_13]
        - fold_14 = [fold_14]
        - fold_15 = [fold_15]
        - fold_16 = [fold_16]
        - fold_17 = [fold_17]
        - fold_18 = [fold_18]
        - fold_19 = [fold_19]
        - fold_20 = [fold_20]
    ]

    [chip_row:
        [chip, "•": B [digest_b]]
        [chip, "•": C [digest_c]]
        [chip, "•": D [digest_d]]
        [chip, "•": grand [grand_digest]]
    ]
]

BenchmarkBlock = |
    title String,
    body String,
    seed Int,
    group String,
|

RuntimeMetric = |
    label String,
    base Int,
    stride Int,
|

MatrixSpec = |
    width Int,
    height Int,
    offset Int,
|

compute_score |this BenchmarkBlock, index Int| -> Int:
    return (this.seed * (index + 3)) + (index * index) + 17
;

render |this BenchmarkBlock, index Int| -> String:
    tone ~= "even"
    residue = this.compute_score(index) % 3
    if residue is 1:
        tone = "odd"
    ;
    if residue is 2:
        tone = "alt"
    ;

    composite = this.compute_score(index)
    emphasis = composite % 97

    return [:
        <article class="runtime-card [tone]">
            <h3>[this.title]</h3>
            <p class="muted">[this.body]</p>
            <div>group [this.group]</div>
            <div>seed [this.seed]</div>
            <div>index [index]</div>
            <div>composite [composite]</div>
            <div>emphasis [emphasis]</div>
        </article>
    ]
;

bump |this ~RuntimeMetric, amount Int|:
    this.base = this.base + amount
    this.stride = this.stride + 1
;

value_at |this RuntimeMetric, index Int| -> Int:
    return this.base + ((index + 1) * this.stride) + (index * index)
;

render_row |this RuntimeMetric, index Int| -> String:
    row_class ~= "even"
    if index % 2 is not 0:
        row_class = "odd"
    ;
    if index % 5 is 0:
        row_class = "alt"
    ;

    value = this.value_at(index)
    residue = value % 89

    return [:
        <div class="runtime-row [row_class]">
            <span>[this.label]</span>
            <span>value [value]</span>
            <span>residue [residue]</span>
            <span>index [index]</span>
        </div>
    ]
;

render_matrix |this MatrixSpec| -> String:
    matrix ~= [:
        <div class="matrix">
    ]

    loop 0 to this.height |outer|:
        row_template ~= [:
            <div class="matrix-row">
        ]

        loop 0 to this.width |inner|:
            value = ((outer + 1) * (inner + 2)) + (outer * inner) + this.offset

            cell_class ~= "cell cool"
            if value % 4 is 0:
                cell_class = "cell hot"
            ;

            row_template = [:
                [row_template]
                <span class="[cell_class]">[value]</span>
            ]
        ;

        row_template = [:
            [row_template]
            </div>
        ]

        matrix = [:
            [matrix]
            [row_template]
        ]
    ;

    matrix = [:
        [matrix]
        </div>
    ]

    return matrix
;

pair_values |seed Int| -> Int, Int:
    left = (seed * 3) + 7
    right = (seed * seed) + 11
    return left, right
;

build_runtime_grid || -> String:
    items = {
        BenchmarkBlock("Runtime alpha", "Exercises collections, loops, receiver methods, and template construction.", 17, "core"),
        BenchmarkBlock("Runtime beta", "Builds up runtime strings by repeatedly wrapping previous content.", 23, "core"),
        BenchmarkBlock("Runtime gamma", "Adds more method-call and interpolation work.", 31, "fold"),
        BenchmarkBlock("Runtime delta", "Uses the same receiver path but different data.", 43, "fold"),
        BenchmarkBlock("Runtime epsilon", "Keeps AST parsing busy in function bodies.", 59, "body"),
        BenchmarkBlock("Runtime zeta", "Good for comparing node emission and template normalization.", 71, "body"),
        BenchmarkBlock("Runtime eta", "Another block to keep collection iteration non-trivial.", 83, "layout"),
        BenchmarkBlock("Runtime theta", "Large enough to make the collection loop visible.", 97, "layout"),
        BenchmarkBlock("Runtime iota", "Additional body parsing and runtime template churn.", 109, "result"),
        BenchmarkBlock("Runtime kappa", "Keeps more struct constructor and method calls active.", 127, "result"),
        BenchmarkBlock("Runtime lambda", "A larger panel set makes repeated runtime wrapping clearer.", 149, "panel"),
        BenchmarkBlock("Runtime mu", "More realistic content volume for frontend-style builds.", 163, "panel"),
    }

    grid ~= [:
        <div class="runtime-grid">
    ]

    loop items |item, index|:
        grid = [:
            [grid]
            [item.render(index)]
        ]
    ;

    grid = [:
        [grid]
        </div>
    ]

    return grid
;

build_runtime_rows || -> String:
    latency ~= RuntimeMetric("latency", 13, 5)
    throughput ~= RuntimeMetric("throughput", 21, 7)
    cache_hit ~= RuntimeMetric("cache-hit", 34, 4)
    render_cost ~= RuntimeMetric("render-cost", 55, 6)
    node_count ~= RuntimeMetric("node-count", 89, 9)
    fold_cost ~= RuntimeMetric("fold-cost", 144, 11)

    ~latency.bump(3)
    ~throughput.bump(5)
    ~cache_hit.bump(2)
    ~render_cost.bump(4)
    ~node_count.bump(6)
    ~fold_cost.bump(8)

    metrics ~= {latency}
    ~metrics.push(throughput)
    ~metrics.push(cache_hit)
    ~metrics.push(render_cost)
    ~metrics.push(node_count)
    ~metrics.push(fold_cost)

    rows ~= [:
        <div class="runtime-table">
    ]

    loop metrics |metric, index|:
        rows = [:
            [rows]
            [metric.render_row(index)]
        ]
    ;

    rows = [:
        [rows]
        </div>
    ]

    return rows
;

build_runtime_matrix || -> String:
    spec = MatrixSpec(16, 12, 13)
    return spec.render_matrix()
;

build_runtime_summary || -> String:
    summary ~= [:
        <div class="summary-grid">
    ]

    loop 0 to 16 |index|:
        metric = ((index + 5) * (index + 9)) + (index * 3) + 41
        residue = metric % 37

        summary = [:
            [summary]
            <div class="summary-item">
                <div>summary [index]</div>
                <div class="muted">metric [metric]</div>
                <div class="muted">residue [residue]</div>
            </div>
        ]
    ;

    summary = [:
        [summary]
        </div>
    ]

    return summary
;

build_mutation_probe || -> String:
    numbers ~= {3, 5, 8, 13, 21}
    ~numbers.push(34)
    ~numbers.push(55)
    ~numbers.set(1, 7)
    ~numbers.remove(3)

    first = numbers.get(0) ! 0
    third = numbers.get(2) ! 0
    missing = numbers.get(99) ! 0

    probe ~= [:
        <div class="runtime-table">
            <div class="runtime-row even">
                <span>first</span>
                <span>[first]</span>
                <span>third</span>
                <span>[third]</span>
            </div>
            <div class="runtime-row odd">
                <span>missing</span>
                <span>[missing]</span>
                <span>state</span>
                <span>mutated</span>
            </div>
    ]

    loop numbers |value, index|:
        class_name ~= "even"
        if index % 2 is not 0:
            class_name = "odd"
        ;

        probe = [:
            [probe]
            <div class="runtime-row [class_name]">
                <span>index [index]</span>
                <span>value [value]</span>
                <span>triple</span>
                <span>[value * 3]</span>
            </div>
        ]
    ;

    probe = [:
        [probe]
        </div>
    ]

    return probe
;

build_descending_series || -> String:
    series ~= [:
        <div class="runtime-table">
    ]

    loop 30 to 0 by 3 |value|:
        folded = (value * value) + (value * 2) + 9
        residue = folded % 11

        class_name ~= "even"
        if value % 2 is not 0:
            class_name = "odd"
        ;

        series = [:
            [series]
            <div class="runtime-row [class_name]">
                <span>descending [value]</span>
                <span>folded [folded]</span>
                <span>residue [residue]</span>
                <span>step 3</span>
            </div>
        ]
    ;

    series = [:
        [series]
        </div>
    ]

    return series
;

build_pair_panels || -> String:
    pairs ~= [:
        <div class="pair-grid">
    ]

    loop 4 to 13 |seed|:
        left, right = pair_values(seed)

        pairs = [:
            [pairs]
            <div class="pair-card">
                <div>seed [seed]</div>
                <div class="muted">left [left]</div>
                <div class="muted">right [right]</div>
                <div class="muted">delta [right - left]</div>
            </div>
        ]
    ;

    pairs = [:
        [pairs]
        </div>
    ]

    return pairs
;

runtime_grid = build_runtime_grid()
runtime_rows = build_runtime_rows()
runtime_matrix = build_runtime_matrix()
runtime_summary = build_runtime_summary()
runtime_mutation_probe = build_mutation_probe()
runtime_descending_series = build_descending_series()
runtime_pair_panels = build_pair_panels()

