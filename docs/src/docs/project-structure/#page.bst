page_title #= "Project structure"
page_description #= "How Beanstalk projects are structured, how modules are discovered, and how the HTML builder emits pages."
page_head #= language_theme_head

#[navbar]

#[section, $md:
    @../ (Documentation) / Project structure

    # Project structure

    A Beanstalk project is a set of modules, one strict project config and a builder
    that decides what those modules produce.

    The root filename begins with `#`, but the name after it is deliberately
    unimportant. The source tells the compiler what is public. The builder decides
    whether the module becomes an artifact.
]

