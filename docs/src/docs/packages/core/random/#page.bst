page_title #= "Core Random"
page_description #= "Random number helpers in the Core package."
page_head #= theme_head

#[navbar]
#[title, center: CORE RANDOM]

#[section, $md:
    `@core/random` provides basic random number helpers for the HTML JavaScript path.

    `random_float()` returns a `Float`.
    `random_int(min, max)` returns an `Int` in the inclusive range from `min` to `max`.
    If `min` is greater than `max`, the bounds are swapped.

    [codeblock, $code("bst"):
        import @core/random {random_float, random_int}

        value = random_float()
        die_roll = random_int(1, 6)

        io.line([:roll=[die_roll] value=[value]])
    ]

    Seeded random is deferred.
]
