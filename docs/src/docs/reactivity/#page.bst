page_title #= "Reactivity"
page_description #= "Reactive sources, template subscriptions and live sinks in Beanstalk."
page_head #= language_theme_head

#[navbar]

#[section, $md:
    @../ (Documentation) / Reactivity

    # Reactivity

    Reactivity lets a template observe a stable source without turning Beanstalk
    into a callback language.

    Sources are explicit. Subscriptions are explicit. Mutation still follows the
    ordinary type and access rules.
]

