page_head #= language_theme_head

#[navbar]

#[section, $md:
    @../ (Documentation) / Templates

    # Templates

    Templates are Beanstalk's superpowered strings. They can stay tiny, or grow into a compile-time HTML and Markdown engine with slots, wrappers and control flow.

    Square brackets look unusual for about five minutes. Then ordinary string formatting starts to feel underdressed.
]

